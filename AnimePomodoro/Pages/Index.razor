@page "/"
@using System.Threading
@using System.Globalization
@inject IJSRuntime JSRuntime

<div class="lofi-bg">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
</div>

<div class="page">
    <div class="card">

        <div class="app-header">
            <div class="app-title">🌙 AnimePomodoro</div>
            <div class="app-subtitle">lofi study timer</div>
        </div>

        <div class="mode-tabs">
            <button class="@ModeTabClass("Pomodoro")"    @onclick="@(() => SetTimer(25))">Pomodoro</button>
            <button class="@ModeTabClass("Short Break")" @onclick="@(() => SetTimer(5))">Short</button>
            <button class="@ModeTabClass("Long Break")"  @onclick="@(() => SetTimer(10))">Long</button>
        </div>

        <div class="timer-ring-wrapper">
            <svg class="timer-svg" viewBox="0 0 100 100">
                <defs>
                    <linearGradient id="ringGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%"   stop-color="#e8a0bf" />
                        <stop offset="100%" stop-color="#9b89b4" />
                    </linearGradient>
                </defs>
                <circle class="ring-track" cx="50" cy="50" r="44" />
                <circle class="ring-fill"  cx="50" cy="50" r="44"
                        style="stroke-dashoffset: @ProgressOffset.ToString("F2", CultureInfo.InvariantCulture)" />
            </svg>
            <div class="timer-inner">
                <div class="timer-digits">@outputPomodoroTime</div>
                <div class="timer-mode-label">@counterType</div>
            </div>
        </div>

        <div class="controls">
            <button class="btn-start" @onclick="@(async () => await StartPomodoro())">&#9654; Start</button>
            <button class="btn-pause" @onclick="PausePomodoro">&#9646;&#9646; Pause</button>
        </div>

        <div class="pomodoro-count">
            <div class="count-dots">
                @{ int filled = pomodoroCount > 0 && pomodoroCount % 4 == 0 ? 4 : pomodoroCount % 4; }
                @for (int i = 0; i < 4; i++)
                {
                    <div class="count-dot @(i < filled ? "filled" : "")"></div>
                }
            </div>
            <span class="count-label">@pomodoroCount pomodoro@(pomodoroCount != 1 ? "s" : "")</span>
        </div>

        <div class="timer-message @(!string.IsNullOrEmpty(message) ? "visible" : "")">
            @if (!string.IsNullOrEmpty(message)) { <span>✨ @message</span> }
        </div>

        <img class="anime-image"
             src="assets/images/image-1779481709337.webp"
             alt="lofi study girl" />

        <div class="player">
            <span class="player-note">♫</span>
            <span class="player-track">lofi hip hop radio</span>
            <button class="btn-player" @onclick="ToggleMusic">
                @(isPlaying ? "⏸" : "▶")
            </button>
            <input type="range" class="player-volume" min="0" max="100" value="@volume"
                   @oninput="OnVolumeChange" />
        </div>

    </div>

    <footer class="app-footer">
        <div>Developed by <a href="https://www.linkedin.com/in/moacyr-pinheiro-278686110/" target="_blank">Moacyr Pinheiro</a></div>
    </footer>
</div>

@if (playAlarm)
{
    <embed src="/assets/audio/Alarm.mp3" autostart="false" type="audio/mpeg"
           loop="false" width="0" height="0" id="beep" enablejavascript="true" />
}

@code {
    private bool playAlarm = false;
    private bool pomodoroPause = true;

    private TimeSpan pomodoroTime  = TimeSpan.FromMinutes(25);
    private TimeSpan _initialTime  = TimeSpan.FromMinutes(25);

    private int    pomodoroCount      = 0;
    private string counterType        = "Pomodoro";
    private string message            = "";
    private string outputPomodoroTime = "25:00";

    private bool isPlaying = false;
    private int  volume    = 50;

    private CancellationTokenSource cts = new();

    // Circumference of r=44 circle: 2π×44 ≈ 276.46
    private double ProgressOffset
    {
        get
        {
            if (_initialTime.TotalSeconds <= 0) return 0;
            var elapsed = _initialTime.TotalSeconds - pomodoroTime.TotalSeconds;
            return 276.46 * (elapsed / _initialTime.TotalSeconds);
        }
    }

    private string ModeTabClass(string mode) =>
        counterType == mode ? "mode-tab active" : "mode-tab";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JSRuntime.InvokeVoidAsync("setTitle", outputPomodoroTime);
        if (firstRender)
            await JSRuntime.InvokeVoidAsync("lofi.init", volume);
    }

    private async Task ToggleMusic()
    {
        isPlaying = !isPlaying;
        if (isPlaying)
            await JSRuntime.InvokeVoidAsync("lofi.play");
        else
            await JSRuntime.InvokeVoidAsync("lofi.pause");
    }

    private async Task OnVolumeChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var vol))
        {
            volume = vol;
            await JSRuntime.InvokeVoidAsync("lofi.setVolume", vol);
        }
    }

    public void SetTimer(int value)
    {
        counterType = value switch
        {
            5  => "Short Break",
            10 => "Long Break",
            _  => "Pomodoro"
        };

        message = "";
        PausePomodoro();
        pomodoroTime  = TimeSpan.FromMinutes(value);
        _initialTime  = pomodoroTime;
        outputPomodoroTime = $"{(int)pomodoroTime.TotalMinutes}:{pomodoroTime.Seconds:00}";
        playAlarm = false;
        StateHasChanged();
    }

    public void PausePomodoro()
    {
        if (!pomodoroPause)
        {
            pomodoroPause = true;
            cts.Cancel();
            cts.Dispose();
        }
    }

    public async Task StartPomodoro()
    {
        if (pomodoroPause)
        {
            cts = new CancellationTokenSource();
            pomodoroPause = false;
            await CountPomodoro(cts.Token);
        }
    }

    private async Task CountPomodoro(CancellationToken cToken)
    {
        if (pomodoroTime <= TimeSpan.Zero) return;

        var timer     = new PeriodicTimer(TimeSpan.FromSeconds(1));
        var startTime = DateTime.UtcNow;

        try
        {
            while (await timer.WaitForNextTickAsync(cToken))
            {
                var elapsed = DateTime.UtcNow - startTime;
                pomodoroTime = _initialTime - elapsed;

                if (pomodoroTime <= TimeSpan.Zero)
                {
                    pomodoroTime = TimeSpan.Zero;
                    outputPomodoroTime = "0:00";
                    StateHasChanged();
                    break;
                }

                outputPomodoroTime = $"{(int)pomodoroTime.TotalMinutes}:{pomodoroTime.Seconds:00}";
                StateHasChanged();
            }
        }
        catch (OperationCanceledException)
        {
            return;
        }

        if (!cToken.IsCancellationRequested)
        {
            if (counterType == "Pomodoro") pomodoroCount++;
            playAlarm = true;
            message   = "Your " + counterType + " has ended";
            StateHasChanged();
            counterType = "Pomodoro";
        }
    }
}
